        {status === "error" && (
          <div className="flex items-center gap-2 text-sm px-3 py-2 rounded-lg mb-4" style={{ background: COLORS.redSoft, color: COLORS.red }}>
            <AlertTriangle size={16} /> No se pudo conectar: {errMsg}
