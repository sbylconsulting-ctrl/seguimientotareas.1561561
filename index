);
const InfoRow = ({ label, value }) => (
  <div className="flex items-center justify-between py-1.5 text-sm border-b last:border-0" style={{ borderColor: COLORS.line }}>
    <span style={{ color: COLORS.textDim }}>{label}</span><span className="font-medium">{value}</span>
  </div>
);
const UpdateRow = ({ label, value }) => !value ? null : (
  <p className="text-sm mt-1.5"><span className="font-medium">{label}:</span> {value}</p>
);
const EmptyState = ({ text }) => (
  <div className="rounded-2xl border border-dashed p-8 text-center text-sm" style={{ borderColor: COLORS.line, color: COLORS.textDim }}>{text}</div>
);

/* ---------------------------------------------------------------
   USERS MANAGEMENT (admin only)
---------------------------------------------------------------- */
function UsersPage({ users, onChange, currentEmail }) {
  const [showNew, setShowNew] = useState(false);
  const [editing, setEditing] = useState(null);

  const addUser = (u) => {
    if (users.some((x) => x.email === u.email)) return;
    onChange([...users, { ...u, id: uid(), active: true, createdAt: todayISO() }]);
    setShowNew(false);
  };
  const saveEdit = (u) => {
    onChange(users.map((x) => (x.id === editing.id ? { ...x, ...u } : x)));
    setEditing(null);
  };
  const toggleActive = (id) => {
    onChange(users.map((x) => (x.id === id ? { ...x, active: !x.active } : x)));
  };

  return (
    <div>
      <div className="flex items-center justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>Usuarios</h1>
          <p className="text-sm mt-1" style={{ color: COLORS.textDim }}>Da de alta a las personas que pueden acceder y decide qué ven.</p>
        </div>
        <button onClick={() => setShowNew(true)} className="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white" style={{ background: COLORS.accent }}>
          <Plus size={16} /> Nuevo usuario
        </button>
      </div>

      <div className="rounded-2xl border overflow-hidden" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
        <table className="w-full text-sm">
          <thead>
            <tr className="text-left border-b" style={{ borderColor: COLORS.line, color: COLORS.textDim }}>
              <th className="px-4 py-3 font-medium">Nombre</th>
              <th className="px-4 py-3 font-medium">Correo</th>
              <th className="px-4 py-3 font-medium">Rol</th>
              <th className="px-4 py-3 font-medium">Estado</th>
              <th className="px-4 py-3 font-medium"></th>
            </tr>
          </thead>
          <tbody>
            {users.map((u) => (
              <tr key={u.id} className="border-b last:border-0" style={{ borderColor: COLORS.line }}>
                <td className="px-4 py-3 font-medium">{u.name} {u.email === currentEmail && <span className="text-xs font-normal" style={{ color: COLORS.textDim }}>(tú)</span>}</td>
                <td className="px-4 py-3" style={{ color: COLORS.textDim }}>{u.email}</td>
                <td className="px-4 py-3"><Pill color={COLORS.accent} soft={COLORS.accentSoft}>{u.role}</Pill></td>
                <td className="px-4 py-3">
                  <button
                    onClick={() => u.email !== currentEmail && toggleActive(u.id)}
                    disabled={u.email === currentEmail}
                    className="text-xs font-semibold px-2.5 py-1 rounded-full"
                    style={{ background: u.active ? COLORS.greenSoft : "#F1F2F0", color: u.active ? COLORS.green : COLORS.textDim, opacity: u.email === currentEmail ? 0.6 : 1 }}
                  >
                    {u.active ? "Activo" : "Inactivo"}
                  </button>
                </td>
                <td className="px-4 py-3 text-right">
                  <button onClick={() => setEditing(u)} className="p-1.5 rounded-lg hover:bg-gray-100"><Pencil size={14} color={COLORS.textDim} /></button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {showNew && (
        <Modal title="Nuevo usuario" onClose={() => setShowNew(false)}>
          <UserForm onCancel={() => setShowNew(false)} onSave={addUser} existing={users} />
        </Modal>
      )}
      {editing && (
        <Modal title="Editar usuario" onClose={() => setEditing(null)}>
          <UserForm initial={editing} onCancel={() => setEditing(null)} onSave={saveEdit} existing={users} />
        </Modal>
      )}
    </div>
  );
}

function UserForm({ initial, onSave, onCancel, existing }) {
  const [f, setF] = useState(initial || { name: "", email: "", role: "Stakeholder" });
  const set = (k) => (e) => setF({ ...f, [k]: e.target.value });
  const emailTaken = !initial && existing.some((u) => u.email === f.email.trim().toLowerCase());
  const valid = f.name.trim() && validEmail(f.email) && !emailTaken;
  return (
    <div>
      <Field label="Nombre">
        <input className={inputCls} style={inputStyle} value={f.name} onChange={set("name")} />
      </Field>
      <Field label="Correo" hint={emailTaken ? "Ya existe un usuario con este correo." : "Con este correo entrará a la aplicación."}>
        <input className={inputCls} style={inputStyle} value={f.email} onChange={(e) => setF({ ...f, email: e.target.value.toLowerCase() })} disabled={!!initial} />
      </Field>
      <Field label="Rol">
        <select className={inputCls} style={inputStyle} value={f.role} onChange={set("role")}>
          {ROLES.map((r) => <option key={r}>{r}</option>)}
        </select>
      </Field>
      <div className="flex justify-end gap-2 pt-2">
        <button onClick={onCancel} className="px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-100">Cancelar</button>
        <button disabled={!valid} onClick={() => onSave({ ...f, name: f.name.trim(), email: f.email.trim().toLowerCase() })} style={{ background: valid ? COLORS.accent : "#C7C8E8" }} className="px-4 py-2 rounded-lg text-sm font-medium text-white">
          {initial ? "Guardar cambios" : "Dar de alta"}
        </button>
      </div>
    </div>
  );
}

/* ---------------------------------------------------------------
   NOTIFICATIONS BELL
---------------------------------------------------------------- */
function NotificationsBell({ notifications, currentEmail, onOpenProject, onMarkRead }) {
  const [open, setOpen] = useState(false);
  const mine = notifications.filter((n) => n.toEmail === currentEmail).sort((a, b) => new Date(b.date) - new Date(a.date));
  const unread = mine.filter((n) => !n.read).length;
  return (
    <div className="relative">
      <button onClick={() => setOpen(!open)} className="relative p-2 rounded-lg hover:bg-gray-100 transition">
        <Bell size={18} color={COLORS.ink} />
        {unread > 0 && (
          <span className="absolute -top-0.5 -right-0.5 w-4 h-4 rounded-full text-[10px] font-bold text-white flex items-center justify-center" style={{ background: COLORS.red }}>{unread}</span>
        )}
      </button>
      {open && (
        <>
          <div className="fixed inset-0 z-30" onClick={() => setOpen(false)} />
          <div className="absolute right-0 mt-2 w-80 bg-white rounded-2xl border shadow-xl z-40 overflow-hidden" style={{ borderColor: COLORS.line }}>
            <div className="px-4 py-3 border-b font-semibold text-sm" style={{ borderColor: COLORS.line }}>Notificaciones</div>
            <div className="max-h-80 overflow-y-auto">
              {mine.length === 0 && <p className="text-sm p-4" style={{ color: COLORS.textDim }}>Sin notificaciones.</p>}
              {mine.map((n) => (
                <button
                  key={n.id}
                  onClick={() => { onMarkRead(n.id); onOpenProject(n.projectId); setOpen(false); }}
                  className="w-full text-left px-4 py-3 border-b last:border-0 hover:bg-gray-50 transition"
                  style={{ borderColor: COLORS.line, background: n.read ? "white" : COLORS.accentSoft }}
                >
                  <p className="text-sm">{n.message}</p>
                  <span className="text-xs" style={{ color: COLORS.textDim }}>{fmtDateTime(n.date)}</span>
                </button>
              ))}
            </div>
          </div>
        </>
      )}
    </div>
  );
}

