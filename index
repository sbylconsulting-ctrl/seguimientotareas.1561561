        </div>
        <h1 className="text-xl font-bold mb-1" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>Conectar con Google Sheet</h1>
        <p className="text-sm mb-5" style={{ color: COLORS.textDim }}>
          Pega la URL de tu Apps Script Web App (termina en <code>/exec</code>). Todos los que usen esta app compartirán los mismos datos, guardados en tu Sheet.
        </p>
        <Field label="URL de la Web App">
          <input
            className={inputCls} style={inputStyle}
            placeholder="https://script.google.com/macros/s/XXXXX/exec"
            value={url}
            onChange={(e) => { setUrl(e.target.value); setStatus("idle"); }}
          />
        </Field>
        {status === "ok" && (
          <div className="flex items-center gap-2 text-sm px-3 py-2 rounded-lg mb-4" style={{ background: COLORS.greenSoft, color: COLORS.green }}>
            <CheckCircle2 size={16} /> Conexión correcta.
