                    </div>
                    <span className="text-xs" style={{ color: COLORS.textDim }}>{fmtDate(r.createdAt)}</span>
                  </div>
                  <p className="text-sm">{r.description}</p>
                  {r.mitigation && <p className="text-xs mt-2" style={{ color: COLORS.textDim }}><b>Mitigación:</b> {r.mitigation}</p>}
                  {r.owner && <p className="text-xs mt-1" style={{ color: COLORS.textDim }}><b>Responsable:</b> {r.owner}</p>}
                </div>
              );
            })}
          </div>
        </div>
      )}

      {tab === "actualizaciones" && (
        <div>
          {canEdit && (
            <button onClick={() => setShowUpdateForm(true)} className="flex items-center gap-1.5 mb-4 px-3 py-2 rounded-lg text-sm font-medium text-white" style={{ background: COLORS.accent }}>
              <Plus size={14} /> Nueva actualización semanal
            </button>
          )}
          <div className="space-y-3">
            {project.updates.length === 0 && <EmptyState text="Sin actualizaciones registradas todavía." />}
            {[...project.updates].reverse().map((u) => (
              <div key={u.id} className="rounded-2xl border p-4" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
                <div className="flex items-center justify-between mb-2">
                  <span className="text-sm font-medium">{fmtDate(u.date)}</span>
                  <span className="text-xs" style={{ color: COLORS.textDim }}>{u.author}</span>
                </div>
                <UpdateRow label="Avances" value={u.advances} />
                <UpdateRow label="Cambios de estado" value={u.statusChange} />
                <UpdateRow label="Nuevos riesgos" value={u.newRisks} />
                <UpdateRow label="Próximos pasos" value={u.nextSteps} />
                <UpdateRow label="Decisiones necesarias" value={u.decisions} />
              </div>
            ))}
          </div>
        </div>
      )}

      {tab === "compartir" && isAdmin && (
        <div className="max-w-lg">
          <SharePanel
            project={project}
            users={users}
            onChange={(newSharedWith, notify) => {
              onShare({ ...project, sharedWith: newSharedWith }, notify);
            }}
          />
        </div>
      )}

      {showEdit && (
        <Modal title="Editar proyecto" onClose={() => setShowEdit(false)} wide>
          <ProjectForm initial={project} onCancel={() => setShowEdit(false)} onSave={(f) => { onUpdate({ ...project, ...f }); setShowEdit(false); }} />
        </Modal>
      )}
      {showPhase && (
        <Modal title="Añadir fase" onClose={() => setShowPhase(false)} wide>
          <PhaseForm onCancel={() => setShowPhase(false)} onSave={(f) => { onUpdate({ ...project, phases: [...project.phases, { ...f, id: uid() }] }); setShowPhase(false); }} />
        </Modal>
      )}
      {showRisk && (
        <Modal title="Registrar riesgo" onClose={() => setShowRisk(false)}>
          <RiskForm onCancel={() => setShowRisk(false)} onSave={(f) => { onUpdate({ ...project, risks: [...project.risks, { ...f, id: uid(), createdAt: todayISO() }] }); setShowRisk(false); }} />
        </Modal>
      )}
      {showUpdateForm && (
        <Modal title="Nueva actualización semanal" onClose={() => setShowUpdateForm(false)} wide>
          <UpdateForm
            project={project}
            onCancel={() => setShowUpdateForm(false)}
            onSave={(f) => {
              onUpdate({
                ...project,
                updates: [...project.updates, { ...f, id: uid() }],
                semaphore: f.semaphore,
                lastUpdateAt: f.date,
              }, f.semaphore === "red");
              setShowUpdateForm(false);
            }}
          />
        </Modal>
      )}
    </div>
  );
