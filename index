/* ---------------------------------------------------------------
   STORAGE HOOKS
   - useSheetApiUrl: dirección del Apps Script, guardada en localStorage
     de este navegador (cada persona la pega una vez).
   - useSheetCollection: lee/escribe una "tabla" en el Sheet vía fetch()
     contra el Apps Script (funciona porque GitHub Pages no tiene las
     restricciones de red de un artifact de Claude).
   - useSession: quién ha iniciado sesión en este navegador.
---------------------------------------------------------------- */
async function sheetGet(apiUrl, key) {
  const res = await fetch(`${apiUrl}?action=get&key=${encodeURIComponent(key)}`);
  const json = await res.json();
  if (!json.ok) throw new Error(json.error || "Error al leer del Sheet");
  return json.value ? JSON.parse(json.value) : null;
}

async function sheetSet(apiUrl, key, value) {
  const res = await fetch(apiUrl, {
    method: "POST",
    headers: { "Content-Type": "text/plain;charset=utf-8" }, // evita preflight CORS en Apps Script
    body: JSON.stringify({ action: "set", key, value: JSON.stringify(value) }),
  });
  const json = await res.json();
  if (!json.ok) throw new Error(json.error || "Error al guardar en el Sheet");
  return true;
}

async function sheetTestConnection(apiUrl) {
  const res = await fetch(`${apiUrl}?action=list&prefix=`);
  const json = await res.json();
  if (!json.ok) throw new Error(json.error || "Respuesta inválida");
  return true;
}

function useSheetApiUrl() {
  const [url, setUrlState] = useState(() => {
    try { return JSON.parse(localStorage.getItem("sheet-api-url") || "null"); } catch { return null; }
  });
  const setUrl = useCallback((val) => {
    setUrlState(val);
    try { localStorage.setItem("sheet-api-url", JSON.stringify(val)); } catch { /* non-fatal */ }
  }, []);
  return { url, setUrl, loading: false };
}

function useSheetCollection(apiUrl, key, seed) {
  const [data, setData] = useState(seed || []);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    if (!apiUrl) return;
    (async () => {
      setLoading(true);
      try {
        let value = await sheetGet(apiUrl, key);
        if (!value) {
          value = seed || [];
          await sheetSet(apiUrl, key, value);
        }
        setData(value);
        setError(null);
      } catch (e) {
        setError("No se pudo conectar con el Sheet (" + e.message + ").");
      } finally {
        setLoading(false);
      }
    })();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [key, apiUrl]);

  const persist = useCallback(async (next) => {
    setData(next);
    if (!apiUrl) return;
    setSaving(true);
    try {
      await sheetSet(apiUrl, key, next);
      setError(null);
    } catch (e) {
      setError("No se pudo guardar en el Sheet (" + e.message + ").");
    } finally {
      setSaving(false);
    }
  }, [key, apiUrl]);

  return { data, setData: persist, loading, error, saving };
}

function useSession() {
  const [email, setEmailState] = useState(() => {
    try { return JSON.parse(localStorage.getItem("session-email") || "null"); } catch { return null; }
  });
