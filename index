function ConfigureSheet({ initialUrl, onSaved }) {
  const [url, setUrl] = useState(initialUrl || "");
  const [status, setStatus] = useState("idle"); // idle | testing | ok | error
  const [errMsg, setErrMsg] = useState("");

  const test = async () => {
    setStatus("testing");
    setErrMsg("");
    try {
      await sheetTestConnection(url.trim());
      setStatus("ok");
    } catch (e) {
      setStatus("error");
      setErrMsg(e.message);
    }
  };

  return (
    <div className="min-h-screen flex items-center justify-center px-4" style={{ background: COLORS.paper, fontFamily: "'Inter', sans-serif" }}>
      <style>{FONT_IMPORT}</style>
      <div className="w-full max-w-md bg-white rounded-2xl border p-7" style={{ borderColor: COLORS.line }}>
        <div className="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style={{ background: COLORS.accent }}>
