                  <div className="flex items-center justify-between">
                    <span className="font-medium">{ph.name}</span>
                    <Pill color={ph.status === "Completada" ? COLORS.green : ph.status === "Bloqueada" ? COLORS.red : COLORS.accent} soft={ph.status === "Completada" ? COLORS.greenSoft : ph.status === "Bloqueada" ? COLORS.redSoft : COLORS.accentSoft}>{ph.status}</Pill>
