/* ---------------------------------------------------------------
   SHARE PANEL (admin decides visibility)
---------------------------------------------------------------- */
function SharePanel({ project, users, onChange }) {
  const [email, setEmail] = useState("");
  const isAll = project.sharedWith === "all";
  const list = isAll ? [] : (project.sharedWith || []);
  const candidates = users.filter((u) => u.active && u.email !== "");

  const addShare = (targetEmail) => {
    const e = targetEmail.trim().toLowerCase();
    const registered = users.find((u) => u.email === e && u.active);
    if (!registered) return;
    if (isAll) return;
    if (list.includes(e)) return;
    onChange([...list, e], true);
    setEmail("");
  };
  const removeShare = (e) => {
    onChange(list.filter((x) => x !== e), false);
  };

  return (
    <Section title="Compartir y visibilidad">
      <div className="flex items-center justify-between mb-3">
        <span className="text-sm">Visible para todos los usuarios</span>
        <button
          onClick={() => onChange(isAll ? [] : "all", false)}
          className="text-xs font-semibold px-2.5 py-1 rounded-full"
          style={{ background: isAll ? COLORS.greenSoft : "#F1F2F0", color: isAll ? COLORS.green : COLORS.textDim }}
        >
          {isAll ? "Activado" : "Desactivado"}
        </button>
      </div>
      {!isAll && (
        <>
          <div className="flex gap-2 mb-3">
            <input
              list="user-emails"
              className={inputCls} style={inputStyle}
              placeholder="correo@empresa.com"
              value={email}
              onChange={(e) => setEmail(e.target.value)}
              onKeyDown={(e) => e.key === "Enter" && addShare(email)}
            />
            <datalist id="user-emails">
              {candidates.map((u) => <option key={u.id} value={u.email} />)}
            </datalist>
            <button onClick={() => addShare(email)} className="px-3 py-2 rounded-lg text-sm font-medium text-white whitespace-nowrap" style={{ background: COLORS.accent }}>
              Compartir
            </button>
          </div>
          <p className="text-xs mb-2" style={{ color: COLORS.textDim }}>Solo puedes compartir con correos ya dados de alta como usuario.</p>
          <div className="space-y-1.5">
            {list.length === 0 && <p className="text-sm" style={{ color: COLORS.textDim }}>Nadie más tiene acceso todavía.</p>}
            {list.map((e) => {
              const u = users.find((x) => x.email === e);
              return (
                <div key={e} className="flex items-center justify-between text-sm px-2.5 py-1.5 rounded-lg" style={{ background: COLORS.paper }}>
                  <span>{u ? u.name : e} <span style={{ color: COLORS.textDim }}>· {e}</span></span>
                  <button onClick={() => removeShare(e)} className="p-1 rounded hover:bg-gray-200"><Trash2 size={13} color={COLORS.textDim} /></button>
                </div>
              );
            })}
          </div>
        </>
      )}
    </Section>
  );
}

/* ---------------------------------------------------------------
   DASHBOARD
---------------------------------------------------------------- */
function Dashboard({ projects, onOpen, onNew, canCreate }) {
  const active = projects.filter((p) => !p.archived);
  const counts = { green: 0, amber: 0, red: 0 };
  active.forEach((p) => counts[p.semaphore]++);
  const criticalRisk = active.filter((p) => p.risks.some((r) => r.severity === "Crítica" && r.status !== "Cerrado" && r.status !== "Mitigado"));
  const staleProjects = active.filter((p) => {
    const d = daysSince(p.lastUpdateAt);
    return d === null || d > 7;
  });

  const upcomingMilestones = active
    .flatMap((p) => p.phases.filter((ph) => ph.status !== "Completada" && ph.endDate).map((ph) => ({ ...ph, project: p.name, projectId: p.id })))
    .sort((a, b) => new Date(a.endDate) - new Date(b.endDate))
    .slice(0, 6);

  const [filter, setFilter] = useState("all");
  const [search, setSearch] = useState("");
  const filtered = active.filter((p) => {
    if (filter !== "all" && filter !== "stale" && filter !== "critical" && p.semaphore !== filter) return false;
    if (filter === "stale" && !staleProjects.includes(p)) return false;
    if (search && !p.name.toLowerCase().includes(search.toLowerCase())) return false;
    return true;
  });

  const kpiCard = (label, value, color, icon, key) => (
    <button
      onClick={() => setFilter(filter === key ? "all" : key)}
      className="text-left rounded-2xl p-5 border transition hover:shadow-md flex-1 min-w-[150px]"
      style={{ borderColor: filter === key ? color : COLORS.line, background: COLORS.paperCard, boxShadow: filter === key ? `0 0 0 2px ${color}22` : "none" }}
    >
      <div className="flex items-center justify-between mb-3">
        <span className="text-xs font-semibold uppercase tracking-wide" style={{ color: COLORS.textDim }}>{label}</span>
        <div className="p-1.5 rounded-lg" style={{ background: color + "1A" }}>{icon}</div>
      </div>
      <div className="text-3xl font-bold" style={{ fontFamily: "'Space Grotesk', sans-serif", color: COLORS.ink }}>{value}</div>
    </button>
  );

  const rows = filter === "critical" ? criticalRisk : filtered;

  return (
    <div>
      <div className="flex items-start justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>Dashboard ejecutivo</h1>
          <p className="text-sm mt-1" style={{ color: COLORS.textDim }}>Visión consolidada de los proyectos a los que tienes acceso.</p>
        </div>
        {canCreate && (
          <button onClick={onNew} className="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white transition hover:opacity-90" style={{ background: COLORS.accent }}>
            <Plus size={16} /> Nuevo proyecto
          </button>
        )}
      </div>

      <div className="flex flex-wrap gap-3 mb-6">
        {kpiCard("Proyectos activos", active.length, COLORS.accent, <FolderKanban size={16} color={COLORS.accent} />, "all")}
        {kpiCard("En verde", counts.green, COLORS.green, <CheckCircle2 size={16} color={COLORS.green} />, "green")}
        {kpiCard("En ámbar", counts.amber, COLORS.amber, <AlertTriangle size={16} color={COLORS.amber} />, "amber")}
        {kpiCard("En rojo", counts.red, COLORS.red, <AlertTriangle size={16} color={COLORS.red} />, "red")}
        {kpiCard("Riesgo crítico", criticalRisk.length, COLORS.red, <ShieldAlert size={16} color={COLORS.red} />, "critical")}
        {kpiCard("Sin actualizar", staleProjects.length, COLORS.textDim, <Clock size={16} color={COLORS.textDim} />, "stale")}
      </div>

      <div className="grid grid-cols-3 gap-5 mb-6">
        <div className="col-span-2 rounded-2xl border p-5" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
          <div className="flex items-center justify-between mb-4">
            <h2 className="font-semibold flex items-center gap-2" style={{ fontFamily: "'Space Grotesk', sans-serif" }}><FolderKanban size={16} /> Proyectos</h2>
            <div className="flex items-center gap-2">
              <div className="flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border text-sm" style={{ borderColor: COLORS.line }}>
                <Search size={14} color={COLORS.textDim} />
                <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Buscar…" className="outline-none text-sm w-28" />
              </div>
              {filter !== "all" && (
                <button onClick={() => setFilter("all")} className="text-xs font-medium px-2 py-1 rounded-lg" style={{ background: COLORS.accentSoft, color: COLORS.accent }}>
                  Quitar filtro ✕
                </button>
              )}
            </div>
          </div>
          <div className="divide-y" style={{ borderColor: COLORS.line }}>
            {rows.length === 0 && <p className="text-sm py-6 text-center" style={{ color: COLORS.textDim }}>No hay proyectos que coincidan.</p>}
            {rows.map((p) => {
              const d = daysSince(p.lastUpdateAt);
              return (
                <button key={p.id} onClick={() => onOpen(p.id)} className="w-full flex items-center gap-4 py-3.5 text-left hover:bg-gray-50 transition rounded-lg px-2 -mx-2">
                  <SignalBar semaphore={p.semaphore} />
                  <div className="flex-1 min-w-0">
                    <div className="font-medium truncate">{p.name}</div>
                    <div className="text-xs truncate" style={{ color: COLORS.textDim }}>{p.owner} · {p.priority}</div>
                  </div>
                  {d !== null && d > 7 && (
                    <Pill color={COLORS.textDim} soft="#EEEEEC"><Clock size={11} /> {d}d sin actualizar</Pill>
                  )}
                  <span className="text-xs w-24 text-right" style={{ color: COLORS.textDim }}>Rev. {fmtDate(p.nextReview)}</span>
                  <ChevronRight size={16} color={COLORS.textDim} />
                </button>
              );
            })}
          </div>
        </div>

        <div className="rounded-2xl border p-5" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
          <h2 className="font-semibold flex items-center gap-2 mb-4" style={{ fontFamily: "'Space Grotesk', sans-serif" }}><Milestone size={16} /> Próximos hitos</h2>
          <div className="space-y-3">
            {upcomingMilestones.length === 0 && <p className="text-sm" style={{ color: COLORS.textDim }}>Sin hitos próximos.</p>}
            {upcomingMilestones.map((m) => (
              <button key={m.id} onClick={() => onOpen(m.projectId)} className="w-full text-left block hover:bg-gray-50 rounded-lg p-2 -mx-2 transition">
                <div className="text-sm font-medium truncate">{m.name}</div>
                <div className="text-xs flex items-center gap-1.5 mt-0.5" style={{ color: COLORS.textDim }}>
                  <span>{m.project}</span><span>·</span><Calendar size={11} /><span>{fmtDate(m.endDate)}</span>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}

/* ---------------------------------------------------------------
   PROJECT DETAIL
---------------------------------------------------------------- */
function ProjectDetail({ project, onBack, onUpdate, onShare, onArchive, canEdit, isAdmin, users }) {
  const [tab, setTab] = useState("resumen");
  const [showEdit, setShowEdit] = useState(false);
  const [showPhase, setShowPhase] = useState(false);
  const [showRisk, setShowRisk] = useState(false);
  const [showUpdateForm, setShowUpdateForm] = useState(false);

  const tabs = [
    { id: "resumen", label: "Resumen", icon: <FileText size={14} /> },
    { id: "cronograma", label: "Cronograma", icon: <Milestone size={14} /> },
    { id: "riesgos", label: "Riesgos", icon: <ShieldAlert size={14} /> },
    { id: "actualizaciones", label: "Actualizaciones", icon: <History size={14} /> },
  ];
  if (isAdmin) tabs.push({ id: "compartir", label: "Compartir", icon: <Share2 size={14} /> });

  const sem = SEMAFORO[project.semaphore];

  return (
    <div>
      <button onClick={onBack} className="flex items-center gap-1.5 text-sm font-medium mb-4 hover:opacity-70" style={{ color: COLORS.textDim }}>
        <ChevronLeft size={16} /> Volver al dashboard
      </button>

      <div className="flex items-start justify-between mb-5">
        <div className="flex items-start gap-4">
          <SignalBar semaphore={project.semaphore} />
          <div>
            <h1 className="text-2xl font-bold" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>{project.name}</h1>
            <div className="flex items-center gap-2 mt-1.5 flex-wrap">
              <Pill color={sem.color} soft={sem.soft}>{sem.label}</Pill>
              <Pill color={COLORS.accent} soft={COLORS.accentSoft}>{project.priority}</Pill>
              <span className="text-xs flex items-center gap-1" style={{ color: COLORS.textDim }}><User size={12} /> {project.owner}</span>
              <span className="text-xs flex items-center gap-1" style={{ color: COLORS.textDim }}><Users size={12} /> {project.stakeholders || "—"}</span>
            </div>
          </div>
        </div>
        {canEdit && (
          <div className="flex gap-2">
            <button onClick={() => setShowEdit(true)} className="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium border hover:bg-gray-50" style={{ borderColor: COLORS.line }}>
              <Pencil size={14} /> Editar
            </button>
            {isAdmin && (
              <button onClick={onArchive} className="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium border hover:bg-gray-50" style={{ borderColor: COLORS.line, color: COLORS.textDim }}>
                <Archive size={14} /> Archivar
              </button>
            )}
          </div>
        )}
      </div>

      <div className="flex gap-1 mb-5 border-b" style={{ borderColor: COLORS.line }}>
        {tabs.map((t) => (
          <button
            key={t.id}
            onClick={() => setTab(t.id)}
            className="flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition"
            style={{ borderColor: tab === t.id ? COLORS.accent : "transparent", color: tab === t.id ? COLORS.accent : COLORS.textDim }}
          >
            {t.icon} {t.label}
            {t.id === "riesgos" && project.risks.length > 0 && (
              <span className="text-xs rounded-full px-1.5" style={{ background: COLORS.redSoft, color: COLORS.red }}>{project.risks.length}</span>
            )}
          </button>
        ))}
      </div>

      {tab === "resumen" && (
        <div className="grid grid-cols-3 gap-5">
          <div className="col-span-2 space-y-4">
            <Section title="Resumen ejecutivo"><p className="text-sm leading-relaxed">{project.summary || "—"}</p></Section>
            <Section title="Objetivo del proyecto"><p className="text-sm leading-relaxed">{project.objective}</p></Section>
            <Section title="Estado actual"><p className="text-sm leading-relaxed">{project.currentStatus || "—"}</p></Section>
          </div>
          <div className="space-y-4">
            <Section title="Fechas">
              <InfoRow label="Inicio" value={fmtDate(project.startDate)} />
              <InfoRow label="Fin estimado" value={fmtDate(project.endDate)} />
              <InfoRow label="Próxima revisión" value={fmtDate(project.nextReview)} />
              <InfoRow label="Última actualización" value={fmtDate(project.lastUpdateAt)} />
            </Section>
            <Section title="Visibilidad">
              <p className="text-sm">{project.sharedWith === "all" ? "Visible para todos los usuarios" : `Compartido con ${(project.sharedWith || []).length} usuario(s)`}</p>
            </Section>
          </div>
        </div>
      )}

      {tab === "cronograma" && (
        <div>
          {canEdit && (
            <button onClick={() => setShowPhase(true)} className="flex items-center gap-1.5 mb-4 px-3 py-2 rounded-lg text-sm font-medium text-white" style={{ background: COLORS.accent }}>
              <Plus size={14} /> Añadir fase
            </button>
