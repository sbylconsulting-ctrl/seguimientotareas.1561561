  const [showArchived, setShowArchived] = useState(false);
  const list = projects.filter((p) => (showArchived ? p.archived : !p.archived));
  return (
    <div>
      <div className="flex items-center justify-between mb-6">
        <div>
          <h1 className="text-2xl font-bold" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>Proyectos</h1>
          <p className="text-sm mt-1" style={{ color: COLORS.textDim }}>{list.length} proyecto{list.length !== 1 ? "s" : ""} {showArchived ? "archivados" : "activos"}</p>
        </div>
        <div className="flex gap-2">
          <button onClick={() => setShowArchived(!showArchived)} className="px-3 py-2 rounded-lg text-sm font-medium border hover:bg-gray-50" style={{ borderColor: COLORS.line }}>
            {showArchived ? "Ver activos" : "Ver archivados"}
          </button>
          {canCreate && (
            <button onClick={onNew} className="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold text-white" style={{ background: COLORS.accent }}>
              <Plus size={16} /> Nuevo proyecto
            </button>
          )}
