const Section = ({ title, children }) => (
  <div className="rounded-2xl border p-4" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
    <h3 className="text-xs font-semibold uppercase tracking-wide mb-2" style={{ color: COLORS.textDim }}>{title}</h3>
    {children}
