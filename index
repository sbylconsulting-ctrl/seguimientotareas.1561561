      </div>
      <div className="grid grid-cols-2 gap-4">
        {list.length === 0 && <EmptyState text="No hay proyectos aquí." />}
        {list.map((p) => {
          const sem = SEMAFORO[p.semaphore];
          return (
            <button key={p.id} onClick={() => onOpen(p.id)} className="text-left rounded-2xl border p-5 hover:shadow-md transition" style={{ borderColor: COLORS.line, background: COLORS.paperCard }}>
              <div className="flex items-start gap-3">
                <SignalBar semaphore={p.semaphore} />
                <div className="flex-1 min-w-0">
                  <div className="font-semibold truncate">{p.name}</div>
                  <p className="text-xs mt-1 line-clamp-2" style={{ color: COLORS.textDim }}>{p.summary || p.objective}</p>
                  <div className="flex items-center gap-2 mt-3 flex-wrap">
                    <Pill color={sem.color} soft={sem.soft}>{sem.label}</Pill>
                    <Pill color={COLORS.accent} soft={COLORS.accentSoft}>{p.priority}</Pill>
                  </div>
                </div>
              </div>
            </button>
          );
        })}
      </div>
    </div>
  );
}

/* ---------------------------------------------------------------
   APP SHELL
---------------------------------------------------------------- */
function App() {
  const { url: apiUrl, setUrl: setApiUrl, loading: loadingUrl } = useSheetApiUrl();

  if (loadingUrl) {
    return (
      <div className="min-h-screen flex items-center justify-center" style={{ background: COLORS.paper }}>
        <Loader2 className="animate-spin" size={24} color={COLORS.accent} />
      </div>
    );
  }

  if (!apiUrl) {
    return <ConfigureSheet onSaved={setApiUrl} />;
  }

  return <ConnectedApp apiUrl={apiUrl} onChangeUrl={() => setApiUrl(null)} />;
}

function ConnectedApp({ apiUrl, onChangeUrl }) {
  const { data: allProjects, setData: persistProjects, loading: loadingProjects, error: projectsError, saving } = useSheetCollection(apiUrl, "projects-data", SEED_PROJECTS);
  const { data: users, setData: persistUsers, loading: loadingUsers, error: usersError } = useSheetCollection(apiUrl, "users-data", []);
  const { data: notifications, setData: persistNotifications, error: notifError } = useSheetCollection(apiUrl, "notifications-data", []);
  const { email: sessionEmail, setEmail: setSessionEmail } = useSession();

  const [view, setView] = useState("dashboard");
  const [openId, setOpenId] = useState(null);
  const [showNew, setShowNew] = useState(false);

  const loading = loadingProjects || loadingUsers;
  const connError = projectsError || usersError || notifError;

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center" style={{ background: COLORS.paper }}>
        <Loader2 className="animate-spin" size={24} color={COLORS.accent} />
      </div>
    );
  }

  if (connError) {
    return (
      <div className="min-h-screen flex items-center justify-center px-4" style={{ background: COLORS.paper }}>
        <div className="max-w-sm text-center">
          <AlertTriangle size={28} color={COLORS.red} className="mx-auto mb-3" />
          <p className="text-sm mb-4" style={{ color: COLORS.textDim }}>{connError}</p>
          <button onClick={onChangeUrl} className="px-4 py-2 rounded-lg text-sm font-semibold text-white" style={{ background: COLORS.accent }}>
            Revisar conexión al Sheet
          </button>
        </div>
      </div>
    );
  }

  if (users.length === 0) {
    return (
      <SetupAdmin
        onCreate={async ({ name, email }) => {
          const admin = { id: uid(), name, email, role: "Admin", active: true, createdAt: todayISO() };
          await persistUsers([admin]);
          setSessionEmail(email);
        }}
      />
    );
  }

  const currentUser = users.find((u) => u.email === sessionEmail && u.active);
  if (!currentUser) {
    return <SignIn users={users} onSignIn={setSessionEmail} />;
  }

  const isAdmin = currentUser.role === "Admin";
  const canEditRole = currentUser.role === "Admin" || currentUser.role === "Project Owner";

  const visibleProjects = allProjects.filter((p) => {
    if (isAdmin) return true;
    if (p.sharedWith === "all") return true;
    return Array.isArray(p.sharedWith) && p.sharedWith.includes(currentUser.email);
  });

  const notify = (toEmail, message, projectId) => {
    if (toEmail === currentUser.email) return null;
    return { id: uid(), toEmail, message, projectId, date: new Date().toISOString(), read: false };
  };

  const updateProject = (updated, alsoNotify) => {
    persistProjects(allProjects.map((p) => (p.id === updated.id ? updated : p)));
    if (alsoNotify) {
      const targets = updated.sharedWith === "all"
        ? users.filter((u) => u.active).map((u) => u.email)
        : (updated.sharedWith || []);
      const newNotifs = targets
        .map((e) => notify(e, `${updated.name}: nueva actualización — el proyecto ha cambiado a ${SEMAFORO[updated.semaphore].label}.`, updated.id))
        .filter(Boolean);
      if (newNotifs.length) persistNotifications([...notifications, ...newNotifs]);
    }
  };

  const shareProject = (updated, wasShared) => {
    persistProjects(allProjects.map((p) => (p.id === updated.id ? updated : p)));
    if (wasShared) {
      const prev = allProjects.find((p) => p.id === updated.id);
      const prevList = Array.isArray(prev.sharedWith) ? prev.sharedWith : [];
      const newList = Array.isArray(updated.sharedWith) ? updated.sharedWith : [];
      const newlyAdded = newList.filter((e) => !prevList.includes(e));
      const newNotifs = newlyAdded
        .map((e) => notify(e, `${currentUser.name} te ha dado acceso al proyecto "${updated.name}".`, updated.id))
        .filter(Boolean);
      if (newNotifs.length) persistNotifications([...notifications, ...newNotifs]);
    }
  };

  const archiveProject = (id) => {
    persistProjects(allProjects.map((p) => (p.id === id ? { ...p, archived: true } : p)));
    setOpenId(null);
  };
  const createProject = (f) => {
    const np = { ...f, id: uid(), archived: false, phases: [], risks: [], updates: [], lastUpdateAt: null, sharedWith: isAdmin ? [] : "all" };
    persistProjects([...allProjects, np]);
    setShowNew(false);
  };

  const openProject = visibleProjects.find((p) => p.id === openId);
  const goToProject = (id) => { if (visibleProjects.some((p) => p.id === id)) setOpenId(id); };

  return (
    <div className="min-h-screen" style={{ background: COLORS.paper, fontFamily: "'Inter', sans-serif", color: COLORS.ink }}>
      <style>{FONT_IMPORT}</style>
      <div className="flex">
        <div className="w-56 min-h-screen flex flex-col shrink-0" style={{ background: COLORS.ink }}>
          <div className="px-5 py-5 flex items-center gap-2.5">
            <div className="w-7 h-7 rounded-lg flex items-center justify-center" style={{ background: COLORS.accent }}>
              <Target size={15} color="white" />
            </div>
            <span className="text-white font-semibold" style={{ fontFamily: "'Space Grotesk', sans-serif" }}>Trackr</span>
          </div>
          <nav className="px-3 mt-2 space-y-1">
            <button onClick={() => { setView("dashboard"); setOpenId(null); }} className="w-full flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-medium transition" style={{ background: view === "dashboard" && !openId ? COLORS.inkSoft : "transparent", color: view === "dashboard" && !openId ? "white" : "#9CA3AF" }}>
              <LayoutDashboard size={16} /> Dashboard
            </button>
            <button onClick={() => { setView("projects"); setOpenId(null); }} className="w-full flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-medium transition" style={{ background: view === "projects" && !openId ? COLORS.inkSoft : "transparent", color: view === "projects" && !openId ? "white" : "#9CA3AF" }}>
              <FolderKanban size={16} /> Proyectos
            </button>
            {isAdmin && (
              <button onClick={() => { setView("users"); setOpenId(null); }} className="w-full flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-medium transition" style={{ background: view === "users" && !openId ? COLORS.inkSoft : "transparent", color: view === "users" && !openId ? "white" : "#9CA3AF" }}>
                <ShieldCheck size={16} /> Usuarios
              </button>
            )}
            {isAdmin && (
              <button onClick={onChangeUrl} className="w-full flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-sm font-medium transition" style={{ color: "#9CA3AF" }}>
                <FileText size={16} /> Conexión al Sheet
              </button>
            )}
          </nav>
          <div className="mt-auto px-4 py-4 border-t" style={{ borderColor: "#2A303C" }}>
            <div className="flex items-center gap-2 mb-1">
              <div className="w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold text-white shrink-0" style={{ background: COLORS.accent }}>
                {currentUser.name.charAt(0).toUpperCase()}
              </div>
              <div className="min-w-0">
                <p className="text-sm font-medium text-white truncate">{currentUser.name}</p>
                <p className="text-xs truncate" style={{ color: "#6B7280" }}>{currentUser.role}</p>
              </div>
            </div>
            <button onClick={() => setSessionEmail(null)} className="w-full flex items-center gap-1.5 text-xs mt-2 px-2.5 py-1.5 rounded-lg hover:bg-white/5" style={{ color: "#9CA3AF" }}>
              <LogOut size={12} /> Cambiar de usuario
            </button>
          </div>
        </div>

        <div className="flex-1 px-8 py-7 max-w-6xl">
          <div className="flex justify-end mb-2">
            <NotificationsBell
              notifications={notifications}
              currentEmail={currentUser.email}
              onOpenProject={goToProject}
              onMarkRead={(id) => persistNotifications(notifications.map((n) => (n.id === id ? { ...n, read: true } : n)))}
            />
          </div>

          {openProject ? (
            <ProjectDetail
              project={openProject}
              onBack={() => setOpenId(null)}
              onUpdate={updateProject}
              onShare={shareProject}
              onArchive={() => archiveProject(openProject.id)}
              canEdit={canEditRole}
              isAdmin={isAdmin}
              users={users}
            />
          ) : view === "users" && isAdmin ? (
            <UsersPage users={users} onChange={persistUsers} currentEmail={currentUser.email} />
          ) : view === "dashboard" ? (
            <Dashboard projects={visibleProjects} onOpen={setOpenId} onNew={() => setShowNew(true)} canCreate={isAdmin} />
          ) : (
            <ProjectsList projects={visibleProjects} onOpen={setOpenId} onNew={() => setShowNew(true)} canCreate={isAdmin} />
          )}
        </div>
      </div>

      {showNew && (
        <Modal title="Nuevo proyecto" onClose={() => setShowNew(false)} wide>
          <ProjectForm onCancel={() => setShowNew(false)} onSave={createProject} />
        </Modal>
      )}

      {saving && (
        <div className="fixed bottom-4 right-4 flex items-center gap-2 text-xs px-3 py-2 rounded-lg shadow-lg text-white" style={{ background: COLORS.ink }}>
          <Loader2 className="animate-spin" size={12} /> Guardando en el Sheet…
        </div>
      )}
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
  </script>

  <script>
    (function () {
      try {
        var src = document.getElementById("app-source").textContent;
        var out = Babel.transform(src, { presets: [["react", { runtime: "classic" }]] }).code;
        var s = document.createElement("script");
        s.textContent = out;
        document.body.appendChild(s);
      } catch (err) {
        document.getElementById("root").innerHTML =
          '<div style="font-family:sans-serif;max-width:640px;margin:60px auto;padding:20px;border:1px solid #eee;border-radius:12px;">' +
          '<h2 style="color:#D8483F;">Error al cargar Trackr</h2>' +
          '<p>' + (err && err.message ? err.message : err) + '</p>' +
          '<p style="color:#666;font-size:13px;">Copia este mensaje y compártelo para poder solucionarlo.</p>' +
          "</div>";
        console.error(err);
      }
    })();
  </script>
</body>
</html>
